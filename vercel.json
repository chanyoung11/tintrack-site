{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/i/:username", "destination": "/i.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
